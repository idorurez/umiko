# Windows artifacts
nul
Thumbs.db
desktop.ini

# KiCad lock/autosave files
~*.lck
_autosave-*

# SolidWorks lockfiles (~$xxx.SLDPRT/SLDASM open-file markers)
~$*.SLDPRT
~$*.SLDASM
~$*.sldprt
~$*.sldasm
*.kicad_pcb.bak*
*.kicad_pcb.pre_*.bak
*.kicad_sch.bak*
*.kicad_sch.pre_*.bak

# KiCad project session/workspace state (per-user, not portable)
*.kicad_prl
_*.kicad_prl

# Temp/script files
*.pyc
__pycache__/
scripts/_*.json

# CAD workspace tracked so SW work is recoverable from git.
# Contains hand-authored SW files + auto-extracted per-component
# SLDPRTs from STEP imports. Not the smallest folder but not huge
# either (~60MB), and losing the case CAD would be worse than the
# repo bloat.

# Fab output (regenerable via make_jlc_files.py)
fab/

# IDE state
.history/
.history_trim/

# umiko-backups: local rotating backup zips of prior states.
# Not source-controlled — keep for local recovery only.
umiko-backups/
